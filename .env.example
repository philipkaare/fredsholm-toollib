# Local-dev secrets for docker-compose. Copy this file to `.env` and fill in
# real values. `.env` is gitignored. Production deploys read these as fly
# secrets (set via `fly secrets set ...`), not from this file.
POSTGRES_PASSWORD=change-me
ADMIN_PASSWORD=change-me-strong-password
MAILERSEND_API_TOKEN=mlsn.your-token-here
