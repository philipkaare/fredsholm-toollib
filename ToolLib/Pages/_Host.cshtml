@page
@model ToolLib.Pages._HostModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@using ToolLib
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="da">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Værktøjsbibliotek</title>
    <base href="~/" />
    <link rel="stylesheet" href="css/bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="css/app.css" />
    <link rel="stylesheet" href="ToolLib.styles.css" />
    <link rel="stylesheet" href="_content/Radzen.Blazor/css/default.css">
    <style>
        :root {
            --rz-primary: #4A7C5B;
            --rz-primary-500: #4A7C5B;
            --rz-primary-600: #3B6B4A;
            --rz-primary-700: #2D5239;
            --rz-primary-400: #6B9E7A;
            --rz-primary-300: #8EBB9A;
            --rz-primary-200: #B5D4BC;
            --rz-primary-100: #D8EBD9;
            --rz-on-primary-500: #ffffff;
            --rz-on-primary: #ffffff;
            --rz-secondary: #5A7A65;
            --rz-secondary-500: #5A7A65;
        }
    </style>
</head>
<body>
    <component type="typeof(App)" render-mode="ServerPrerendered" />

    <div id="blazor-error-ui">
        <environment include="Staging,Production">
            Der opstod en uventet fejl. Forsøg at <a href="">genindlæse</a> siden, eller kontakt support.
        </environment>
        <environment include="Development">
            En ubehandlet undtagelse er opstået. Se browserens udviklerkonsol for detaljer.
        </environment>
        <a href="" class="dismiss">🗙</a>
    </div>

    <script src="_content/Radzen.Blazor/Radzen.Blazor.js"></script>
    <script src="_framework/blazor.server.js"></script>
    <script>
        window.submitLoginForm = function (email, password) {
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/auth/login';
            [['email', email], ['password', password]].forEach(([name, value]) => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = name;
                input.value = value;
                form.appendChild(input);
            });
            document.body.appendChild(form);
            form.submit();
        };
    </script>
</body>
</html>
