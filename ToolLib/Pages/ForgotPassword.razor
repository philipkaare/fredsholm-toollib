@page "/glemt-adgangskode"
@using Microsoft.AspNetCore.Identity
@using ToolLib.Models
@inject UserManager<ApplicationUser> UserManager
@inject IEmailService EmailService
@inject IConfiguration Config

<PageTitle>Glemt adgangskode - Fredsholmvej Værktøjsbibliotek</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <RadzenCard>
                <h3 class="text-center mb-4">Glemt adgangskode</h3>

                @if (submitted)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Success">
                        Hvis e-mailadressen er registreret, er der sendt et link til nulstilling af adgangskode.
                        Tjek din indbakke.
                    </RadzenAlert>
                    <div class="text-center mt-3">
                        <a href="/login">Tilbage til log ind</a>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-4">Indtast din e-mailadresse, og vi sender dig et link til at nulstille din adgangskode.</p>
                    <RadzenStack Gap="1rem">
                        <RadzenFormField Text="E-mail">
                            <RadzenTextBox @bind-Value="email" Placeholder="din@email.dk" Style="width:100%" />
                        </RadzenFormField>
                        <RadzenButton Text="Send nulstillingslink" ButtonStyle="ButtonStyle.Primary" Style="width:100%"
                            Click="HandleSubmit" IsBusy="isBusy" />
                    </RadzenStack>
                    <div class="text-center mt-3">
                        <a href="/login">Tilbage til log ind</a>
                    </div>
                }
            </RadzenCard>
        </div>
    </div>
</div>

@code {
    private string email = string.Empty;
    private bool isBusy;
    private bool submitted;

    private async Task HandleSubmit()
    {
        if (string.IsNullOrWhiteSpace(email)) return;

        isBusy = true;
        try
        {
            var user = await UserManager.FindByEmailAsync(email.Trim());
            if (user != null)
            {
                var token = await UserManager.GeneratePasswordResetTokenAsync(user);
                var baseUrl = Config["App:BaseUrl"] ?? "https://localhost";
                var resetUrl = $"{baseUrl}/nulstil-adgangskode?email={Uri.EscapeDataString(user.Email!)}&token={Uri.EscapeDataString(token)}";

                await EmailService.SendAsync(user.Email!,
                    "Nulstil adgangskode - Fredsholmvej Værktøjsbibliotek",
                    $"<p>Du har anmodet om at nulstille din adgangskode.</p>" +
                    $"<p><a href='{resetUrl}'>Klik her for at vælge en ny adgangskode</a></p>" +
                    $"<p>Linket udløber om 24 timer. Har du ikke anmodet om dette, kan du ignorere denne e-mail.</p>");
            }
            submitted = true;
        }
        finally
        {
            isBusy = false;
        }
    }
}
