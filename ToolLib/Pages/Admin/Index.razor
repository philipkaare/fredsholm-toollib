@page "/admin"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject NavigationManager NavigationManager
@inject UserRequestService UserRequestService

<PageTitle>Admin - Værktøjsbibliotek</PageTitle>

<div class="p-3" style="width:100%">
    <h2>Administration</h2>
    <div class="row g-3 mt-1">
        <div class="col-12 col-sm-6 col-md-4 col-lg-3">
            <RadzenCard style="cursor:pointer;height:100%" @onclick='() => NavigationManager.NavigateTo("/admin/brugere")'>
                <RadzenStack Gap="0.5rem" AlignItems="AlignItems.Center">
                    <RadzenIcon Icon="people" Style="font-size:3rem;color:var(--rz-primary)" />
                    <RadzenText TextStyle="TextStyle.H5">Brugerstyring</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2">Opret og slet brugere</RadzenText>
                </RadzenStack>
            </RadzenCard>
        </div>
        <div class="col-12 col-sm-6 col-md-4 col-lg-3">
            <RadzenCard style="cursor:pointer;height:100%;position:relative" @onclick='() => NavigationManager.NavigateTo("/admin/adgangsanmodninger")'>
                <RadzenStack Gap="0.5rem" AlignItems="AlignItems.Center">
                    <div style="position:relative;display:inline-block">
                        <RadzenIcon Icon="person_add" Style="font-size:3rem;color:var(--rz-primary)" />
                        @if (pendingCount > 0)
                        {
                            <span class="badge bg-danger" style="position:absolute;top:-6px;right:-10px;font-size:0.75rem">@pendingCount</span>
                        }
                    </div>
                    <RadzenText TextStyle="TextStyle.H5">Adgangsanmodninger</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2">
                        @(pendingCount > 0 ? $"{pendingCount} ventende" : "Ingen ventende")
                    </RadzenText>
                </RadzenStack>
            </RadzenCard>
        </div>
        <div class="col-12 col-sm-6 col-md-4 col-lg-3">
            <RadzenCard style="height:100%">
                <RadzenStack Gap="0.5rem" AlignItems="AlignItems.Center">
                    <RadzenIcon Icon="mail" Style="@($"font-size:3rem;color:{(todayEmailCount >= 20 ? "var(--rz-danger)" : todayEmailCount >= 15 ? "var(--rz-warning)" : "var(--rz-primary)")}")" />
                    <RadzenText TextStyle="TextStyle.H5">E-mail kvote</RadzenText>
                    <RadzenText TextStyle="TextStyle.Body2">@todayEmailCount / 20 sendt i dag</RadzenText>
                    <RadzenProgressBar Value="@todayEmailCount" Max="20" Style="width:100%" ShowValue="false"
                        ProgressBarStyle="@(todayEmailCount >= 20 ? ProgressBarStyle.Danger : todayEmailCount >= 15 ? ProgressBarStyle.Warning : ProgressBarStyle.Primary)" />
                </RadzenStack>
            </RadzenCard>
        </div>
    </div>
</div>

@code {
    private int pendingCount;
    private int todayEmailCount;

    protected override async Task OnInitializedAsync()
    {
        try { pendingCount = await UserRequestService.GetPendingCountAsync(); }
        catch { /* ignore */ }
        try { todayEmailCount = await UserRequestService.GetTodayEmailCountAsync(); }
        catch { /* ignore */ }
    }
}
