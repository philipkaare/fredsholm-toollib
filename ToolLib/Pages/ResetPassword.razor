@page "/nulstil-adgangskode"
@using Microsoft.AspNetCore.Identity
@using ToolLib.Models
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager NavigationManager

<PageTitle>Nulstil adgangskode - Fredsholmvej Værktøjsbibliotek</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <RadzenCard>
                <h3 class="text-center mb-4">Vælg ny adgangskode</h3>

                @if (invalidLink)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Danger">
                        Linket er ugyldigt eller udløbet. Anmod om et nyt nulstillingslink.
                    </RadzenAlert>
                    <div class="text-center mt-3">
                        <a href="/glemt-adgangskode">Anmod om nyt link</a>
                    </div>
                }
                else if (success)
                {
                    <RadzenAlert AlertStyle="AlertStyle.Success">
                        Din adgangskode er opdateret. Du kan nu logge ind.
                    </RadzenAlert>
                    <div class="text-center mt-3">
                        <RadzenButton Text="Gå til log ind" ButtonStyle="ButtonStyle.Primary"
                            Click='() => NavigationManager.NavigateTo("/login")' />
                    </div>
                }
                else
                {
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <RadzenAlert AlertStyle="AlertStyle.Danger" class="mb-3">@errorMessage</RadzenAlert>
                    }
                    <RadzenStack Gap="1rem">
                        <RadzenFormField Text="Ny adgangskode">
                            <RadzenPassword @bind-Value="password" Placeholder="Min. 8 tegn med tal, stort bogstav og specialtegn" Style="width:100%" />
                        </RadzenFormField>
                        <RadzenFormField Text="Bekræft adgangskode">
                            <RadzenPassword @bind-Value="confirmPassword" Placeholder="Gentag adgangskode" Style="width:100%" />
                        </RadzenFormField>
                        <RadzenButton Text="Gem adgangskode" ButtonStyle="ButtonStyle.Primary" Style="width:100%"
                            Click="HandleSubmit" IsBusy="isBusy" />
                    </RadzenStack>
                }
            </RadzenCard>
        </div>
    </div>
</div>

@code {
    private string password = string.Empty;
    private string confirmPassword = string.Empty;
    private string errorMessage = string.Empty;
    private bool isBusy;
    private bool success;
    private bool invalidLink;
    private string? email;
    private string? token;

    protected override void OnInitialized()
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        email = query["email"];
        token = query["token"];
        if (string.IsNullOrEmpty(email) || string.IsNullOrEmpty(token))
            invalidLink = true;
    }

    private async Task HandleSubmit()
    {
        errorMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Angiv venligst en adgangskode.";
            return;
        }
        if (password != confirmPassword)
        {
            errorMessage = "Adgangskoderne er ikke ens.";
            return;
        }

        isBusy = true;
        try
        {
            var user = await UserManager.FindByEmailAsync(email!);
            if (user == null)
            {
                invalidLink = true;
                return;
            }

            var result = await UserManager.ResetPasswordAsync(user, token!, password);
            if (result.Succeeded)
            {
                success = true;
            }
            else
            {
                var errors = string.Join(" ", result.Errors.Select(e => e.Description));
                errorMessage = errors.Contains("Invalid token") || errors.Contains("token")
                    ? "Linket er udløbet. Anmod om et nyt nulstillingslink."
                    : errors;
            }
        }
        finally
        {
            isBusy = false;
        }
    }
}
