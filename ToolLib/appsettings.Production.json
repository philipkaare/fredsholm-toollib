{
  "ConnectionStrings": {
    "DefaultConnection": "${DATABASE_URL}"
  },
  "MongoDB": {
    "ConnectionString": "${MONGODB_URL}",
    "DatabaseName": "toollib"
  },
  "Smtp": {
    "Host": "${SMTP_HOST}",
    "Port": "${SMTP_PORT}",
    "UseSsl": "${SMTP_USE_SSL}",
    "From": "${SMTP_FROM}",
    "Username": "${SMTP_USERNAME}",
    "Password": "${SMTP_PASSWORD}"
  },
  "App": {
    "BaseUrl": "${APP_BASE_URL}"
  }
}
